{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
   "MongoDB": {
      "ConnectionString": "",
      "DatabaseName": "CollabDb"
    },
    "JwtSettings": {
      "SecretKey": "a-very-long-secret-key-at-least-32-chars!",
      "Issuer": "CollabPlatform",
      "Audience": "CollabPlatform",
      "AccessTokenExpirationMinutes": 15,
      "RefreshTokenExpirationDays": 7
    },
    "Serilog": {
      "MinimumLevel": "Information",
      "WriteTo": [
        { "Name": "Console" }
      ]
    }
}
